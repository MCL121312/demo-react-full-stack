{
  "name": "demo-react-fullstack",
  "private": true,
  "scripts": {
    "predev": "pnpm exec oxfmt apps/ shared/src/",
    "dev": "pnpm -r --parallel dev",
    "check": "pnpm exec oxfmt --check apps/ shared/src/ && pnpm exec oxlint apps/ shared/src/ && pnpm -r typecheck",
    "build": "pnpm -r build",
    "lint": "pnpm exec oxlint apps/ shared/src/",
    "fmt": "pnpm exec oxfmt apps/ shared/src/",
    "typecheck": "pnpm -r typecheck",
    "prepare": "nano-staged"
  },
  "engines": {
    "node": ">=20"
  },
  "nano-staged": {
    "*.{ts,tsx}": [
      "pnpm exec oxfmt",
      "pnpm exec oxlint --fix"
    ]
  },
  "devDependencies": {
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.71.0"
  }
}
